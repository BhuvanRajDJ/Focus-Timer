{
  "name": "focus-timer",
  "version": "1.0.0",
  "description": "Focus Timer — a Windows 11 Pomodoro app with a floating always-on-top mini-window.",
  "main": "out/main/index.js",
  "author": "Focus Timer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "geniconds": "node scripts/gen-icons.mjs",
    "predev": "node scripts/gen-icons.mjs",
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "prebuild": "node scripts/gen-icons.mjs",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "npm run build && electron-builder --win --x64",
    "dist:sign": "npm run build && electron-builder --win --x64 -c.win.signAndEditExecutable=true"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^2.0.3"
  }
}
